# Large data files
*.fits
*.csv
data/*.csv
!data/README.md
!data/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
dist/
*.egg-info/
.venv/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# Output files (don't track generated plots)
output/*.png
output/*.pdf
output/*.jpg
!output/README.md
!output/.gitkeep

# IDE specific
.vscode/
.idea/
*.swp
*.swo
.spyderproject
.spyproject

# OS specific
.DS_Store
Thumbs.db
*.bak

# Temporary files
*.tmp
*.log
*~

# Documentation builds
docs/_build/
